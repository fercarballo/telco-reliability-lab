# Copy to .env to override host-side defaults. Docker Compose already sets the
# in-container values; this file is mainly for running the API locally with
# `npm run dev` against your own Postgres/Redis.

# --- API ---
HTTP_PORT=3000
JWT_SECRET=dev-only-secret-do-not-use-in-prod
JWT_TTL_SECONDS=3600
FAULT_INJECTION_ENABLED=true
LOG_LEVEL=info
LOG_PRETTY=true

# --- PostgreSQL ---
PGHOST=localhost
PGPORT=5432
PGUSER=telco
PGPASSWORD=telco
PGDATABASE=telco

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Observability ---
LOKI_ENABLED=false
LOKI_URL=http://localhost:3100
OTEL_SERVICE_NAME=telco-api
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none
