# dependencies
node_modules/
**/node_modules/

# build output
dist/
**/dist/

# env / secrets
.env
*.local

# logs
*.log
npm-debug.log*

# k6 reports — HTML + JSON summaries are portfolio evidence; commit them.
# Binary/large artifacts (raw JSON logs, etc.) stay ignored.
tests/k6/reports/*
!tests/k6/reports/.gitkeep
!tests/k6/reports/*.html
!tests/k6/reports/*.json

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp
